{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disk Usage Analyzer",
  "version": "0.1.0",
  "identifier": "com.levi.diskusage",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disk Usage Analyzer",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform disk usage explorer.",
    "longDescription": "Disk Usage Analyzer scans local folders and volumes, then summarizes file and folder usage in a native desktop application."
  }
}
